<style>
    .inscripcion-box {
        margin-top: 20px;
        padding: 20px;
        border-radius: 12px;
        background: #f8f9fc;
        border: 1px solid #e4e6ef;
    }

    .btn-inscribirse {
        background: #2c5f2d;
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-inscribirse:hover {
        background: #1e4520;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(44, 95, 45, 0.2);
    }

    .alert-custom {
        margin-top: 15px;
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
    }

    .alert-error {
        background: #fee2e2;
        color: #7f1d1d;
    }
</style>

<div class="inscripcion-box">

    <form asp-controller="Matricula" asp-action="Inscribirse" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="cursoId" value="@Model.Id" />

        <button type="submit" class="btn-inscribirse">
            Inscribirse
        </button>
    </form>

    @if (TempData["Mensaje"] != null)
    {
        var mensaje = TempData["Mensaje"].ToString();
        var esError = mensaje.Contains("no") || mensaje.Contains("conflicto") || mensaje.Contains("ya");

        <div class="alert-custom @(esError ? "alert-error" : "alert-success")">
            @mensaje
        </div>
    }

</div>